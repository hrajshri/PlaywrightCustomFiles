    logger.info(
      `Debug: Case Submission tests = ${caseSubmission.length}, Case Search tests = ${caseSearch.length}, Total = ${allReportData.length}`
    );

    const htmlHeader = getReportHeader(allReportData);
    const tableContent = getReportBodyTouchPointSeparated(caseSubmission, caseSearch);
    const htmlFooter = getReportFooter();
    
    return htmlHeader + tableContent + htmlFooter;
  }
  
  // ✅ Regular UI Test Report (non-touchpoint)
  else if (uiOrApiTestLower.includes("ui") && !isTouchpointTest) {
    console.log("Generating regular UI test report...");
    const uiReportData = captureRegularParameters();
    
    logger.info(`Debug: Regular UI tests = ${uiReportData.length}`);
    
    const htmlHeader = getReportHeader(uiReportData);
    const tableContent = getReportBodyRegularApiOrUi(uiReportData);
    const htmlFooter = getReportFooter();
    
    return htmlHeader + tableContent + htmlFooter;
  }
  
  // ✅ Fallback - Default to touchpoint if unclear
  else {
    console.log("Fallback: Generating touchpoint test report...");
    const { caseSubmission, caseSearch } = captureTouchpointParametersWithTags();
    const allReportData = [...caseSubmission, ...caseSearch];
    
    const htmlHeader = getReportHeader(allReportData);
    const tableContent = getReportBodyTouchPointSeparated(caseSubmission, caseSearch);
    const htmlFooter = getReportFooter();
    
    return htmlHeader + tableContent + htmlFooter;
  }

}

function writeHtmlToFile() {
  const htmlContent = getHtmlOutput();
  const outputFilePath = path.join(
    __dirname,
    "../playwright-report/sanity-test-report.html"
  );
  fs.writeFileSync(outputFilePath, htmlContent, "utf8");
  console.log(
    `✅ Outlook-friendly, compact HTML report generated: ${outputFilePath}`
  );
}

writeHtmlToFile();
console.log("report:", captureTouchpointParametersWithTags());
module.exports = { getHtmlOutput };
