    const htmlHeader = getReportHeader(apiReportData);
    const tableContent = getReportBodyRegularApiOrUi(apiReportData);
    const htmlFooter = getReportFooter();
    
    return htmlHeader + tableContent + htmlFooter;
  }
  
  // ✅ UI Test Report with Touchpoint separation
  else if (uiOrApiTestLower.includes("ui") && isTouchpointTest) {
    console.log("Generating UI touchpoint test report...");
    const { caseSubmission, caseSearch } = captureTouchpointParametersWithTags();
    
    // Combine for summary stats
