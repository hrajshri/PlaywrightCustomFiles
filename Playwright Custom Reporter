function getSummaryStats(reportData) {
  const getStatus = d => d.status || d.Status || "";
  const total = reportData.length;
  const pass = reportData.filter((d) => getStatus(d) === "PASS").length;
  const fail = reportData.filter((d) => getStatus(d) === "FAIL").length;
  const skipped = reportData.filter((d) => getStatus(d) === "SKIPPED").length;
  return { total, pass, fail, skipped };
}

function captureRegularParameters() {
  const reportData = [];
  jsonData.suites.forEach((suite) => {
    suite.suites.forEach((subSuite) => {
      subSuite.specs.forEach((spec) => {
        spec.tests.forEach((test) => {
          const lastResult = test.results[test.results.length - 1];
          let findStatusCodeString = "status code : ";
          let extractedStausCodeSubString = lastResult.stdout.find((line) =>
            line.text?.includes(findStatusCodeString)
          );
          let apiStatusCodeOrAdditionalInfo = "";
          if (extractedStausCodeSubString) {
              apiStatusCodeOrAdditionalInfo =
              extractedStausCodeSubString &&
              typeof extractedStausCodeSubString.text === "string"
                ? extractedStausCodeSubString.text.match(
                    /status code\s*:\s*(\d{3})/
                  )?.[1]
                : "Unavailable";
          } else {
            const caseSubmissionPattern =
              /(\w+)\s+Case\s+is\s+Submitted\s+Successfully\s+with\s+Reference\s+Number:\s+([A-Z]\d+)/;
            extractedStausCodeSubString = lastResult.stdout.find((line) =>
              line.text?.match(caseSubmissionPattern)
            );

            if (extractedStausCodeSubString) {
              const match = extractedStausCodeSubString.text.match(
                caseSubmissionPattern
              );
              apiStatusCodeOrAdditionalInfo = match ? `${match[2]}` : "";
            } 
          }

          reportData.push({
            apiName: spec.title,
            status:
            lastResult.status === "passed"
                ? "PASS"
                : lastResult.duration < 1
                ? "SKIPPED"
                : "FAIL",
            duration: (lastResult.duration / 1000).toFixed(2), // Convert to seconds and format to 2 decimal places
            statusCode: apiStatusCodeOrAdditionalInfo,
            AdditionalInfo: errorSummary = lastResult.errors?.length > 0 ? 
            lastResult.errors[0].message
              .replace(/^Error:\s*/i, '')  // Remove "Error:" prefix
              .replace(/\n/g, ' ')         // Replace newlines with spaces
              .trim()                      // Remove leading/trailing spaces
              .slice(0, 100)               // Limit to 120 characters
            : "",
          });
        });
      });
    });
  });
  // Unique by apiName and status (keep only the last executed result)
  const unique = {};
  reportData.forEach(item => {
    const key = `${item.apiName}`;
    unique[key] = item; // always overwrite, so last one stays
  });
  return Object.values(unique);
}



function captureTouchpointParametersWithTags() {
  const caseSubmissionData = []; // For @OnlyOCMCases
  const caseSearchData = [];     // For @SearchCase

  jsonData.suites.forEach((suite) => {
    suite.suites?.forEach((testSuite) => {
      testSuite.specs?.forEach((spec) => {
        spec.tests?.forEach((test) => {
          // Always use the last result (final attempt)
          const lastResult = test.results[test.results.length - 1];
          
          // ✅ Extract tags from test title or annotations
          const testTags = extractTagsFromTest(test, spec);
          
          const errors = lastResult.errors;
          let errorSummary = "";
          if (errors && errors.length > 1 && errors[1].message) {
            const assertionTextMatch = errors[1].message.match(/(Expected:.*\nReceived:.*\n?)/s);
            let assertionText = assertionTextMatch ? assertionTextMatch[0] : "";
            assertionText = assertionText.replace(/\u001b\[[0-9;]*m/g, "");
            assertionText = assertionText.replace(/"/g, "");

            const match = errors[1].message.match(/^Error: ([^:]*:)/);
            errorSummary = match ? match[1].replace(/:$/, "") + '\n' + assertionText : errors[1].message + assertionText;
          } else if (errors && errors.length > 0 && errors[0].message) {
            const assertionTextMatch = errors[0].message.match(/(Expected:.*\nReceived:.*\n?)/s);
            let assertionText = assertionTextMatch ? assertionTextMatch[0] : "";
            assertionText = assertionText.replace(/\u001b\[[0-9;]*m/g, "");
            assertionText = assertionText.replace(/"/g, "");

            const match = errors[0].message.match(/^Error: ([^:]*:)/);
            errorSummary = match ? match[1].replace(/:$/, "") + '\n' + assertionText : errors[0].message + assertionText;
          }

          if (errorSummary.includes("Test timeout of") && errorSummary.includes("beforeEach")) {
            errorSummary = "Custom Error: Test setup took too long, please check your code.";
          }

          let cleanSummary = errorSummary.replace(/[^\w\s.,:;!?'"()\-]/g, "");
          cleanSummary = cleanSummary.slice(0, 100);

          const testData = {
            Testname: spec.title,
            Status: lastResult.status === "passed" ? "PASS" : lastResult.duration < 1 ? "SKIPPED" : "FAIL",
            TouchPoint1: [],
            TouchPoint2: [],
            TouchPoint3: [],
            TouchPoint4: [],
            TouchPoint5: [],
            TouchPoint6: [],
            TouchPoint7: [],
            CaseNo: [],
            Error: lastResult.errors?.length > 0 ? cleanSummary : "",
            Tags: testTags // Store tags for debugging
          };

          // ✅ Process stdout data for both test types
          if (lastResult.stdout && Array.isArray(lastResult.stdout)) {
            lastResult.stdout.forEach((logEntry) => {
              const text = logEntry.text;

              // ✅ Case Submission specific extractions (@OnlyOCMCases)
              if (testTags.includes('OnlyOCMCases') || testTags.includes('PaanCaseSubmission') || testTags.includes('CasesOCM')) {
                // Touch Point 1 (Member)
                if (text.includes("GetMemberSearch HSCID")) {
                  pushLabeledValue(testData.TouchPoint1, text, "HSCID");
                }
                if (text.includes("Member Search Response Time:")) {
                  pushLabeledValue(testData.TouchPoint1, text, "RespTime");
                }
                if (text.includes("GetMemberSearch CaseManagement")) {
                  pushLabeledValue(testData.TouchPoint1, text, "CM");
                }

                // Touch Point 2 (Provider)
                if (text.includes("SaveCaseProviders HSCID")) {
                  pushLabeledValue(testData.TouchPoint2, text, "HSCID");
                }
                if (text.includes("Provider Response Time:")) {
                  pushLabeledValue(testData.TouchPoint2, text, "RespTime");
                }
                if (text.includes("SaveCaseProviders CaseManagement")) {
                  pushLabeledValue(testData.TouchPoint2, text, "CM");
                }
                if (text.includes("SaveCaseProviders hscProviderId")) {
                  pushLabeledValue(testData.TouchPoint2, text, "HSCPROVIDER");
                }

                // Touch Point 3 (Services)
                if (text.includes("ValidateSubmission HSCID")) {
                  pushLabeledValue(testData.TouchPoint3, text, "HSCID");
                }
                if (text.includes("Validate Submission Response Time:")) {
                  pushLabeledValue(testData.TouchPoint3, text, "RespTime");
                }
                if (text.includes("ValidateSubmission CaseManagement")) {
                  pushLabeledValue(testData.TouchPoint3, text, "CM");
                }
                if (text.includes("ValidateSubmission hscProviderId")) {
                  pushLabeledValue(testData.TouchPoint3, text, "HSCPROVIDER");
                }

                // Touch Point 4 (Create Case)
                if (text.includes("CreateCase HSCID")) {
                  pushLabeledValue(testData.TouchPoint4, text, "HSCID");
                }
                if (text.includes("Create Case Response Time:")) {
                  pushLabeledValue(testData.TouchPoint4, text, "RespTime");
                }
                if (text.includes("CreateCase CaseManagement")) {
                  pushLabeledValue(testData.TouchPoint4, text, "CM");
                }
                if (text.includes("CreateCase hscProviderId")) {
                  pushLabeledValue(testData.TouchPoint4, text, "HSCPROVIDER");
                }

                // Case Reference Number
                if (text.includes("Case Reference Number:")) {
                  pushLabeledValue(testData.CaseNo, text, "CASE#");
                }
              }

              // ✅ Case Search specific extractions (@SearchCase)
              if (testTags.includes('SearchCase') || testTags.includes('CaseSearchTests') || testTags.includes('referenceNumber')) {
                // HSC ID extraction
                if (text.includes("Search HSCID") || text.includes("GetCaseSearch HSCID") || text.includes("GetCaseDetails hscID")) {
                  pushLabeledValue(testData.TouchPoint5, text, "HSCID");
                }
                
                // Case Management extraction
                if (text.includes("Search CaseManagement") || text.includes("GetCaseSearch CaseManagement") || text.includes("GetCaseDetails CaseManagement")) {
                  pushLabeledValue(testData.TouchPoint6, text, "CM");
                }
                
                // Coverage Status extraction
                if (text.includes("Coverage Status") || text.includes("Overall Coverage") || text.includes("GetCaseDetails OverallCoverage")) {
                  pushLabeledValue(testData.TouchPoint7, text, "OC");
                }
                
                // Response Time for Case Search
                if (text.includes("Case Search Response Time:")) {
                  pushLabeledValue(testData.CaseNo, text, "RespTime");
                }
                
                // Case Search Results
                if (text.includes("Case Search Results") || text.includes("Found Cases")) {
                  pushLabeledValue(testData.CaseNo, text, "Results");
                }
              }
            });
          }

          // Join arrays with <br>
          testData.TouchPoint1 = testData.TouchPoint1.join("<br>");
          testData.TouchPoint2 = testData.TouchPoint2.join("<br>");
          testData.TouchPoint3 = testData.TouchPoint3.join("<br>");
          testData.TouchPoint4 = testData.TouchPoint4.join("<br>");
          testData.TouchPoint5 = testData.TouchPoint5.join("<br>");
          testData.TouchPoint6 = testData.TouchPoint6.join("<br>");
          testData.TouchPoint7 = testData.TouchPoint7.join("<br>");
          testData.CaseNo = testData.CaseNo.join("<br>");

          // ✅ Route to appropriate array based on tags
          if (testTags.includes('OnlyOCMCases') || testTags.includes('PaanCaseSubmission') || testTags.includes('CasesOCM')) {
            caseSubmissionData.push(testData);
          } else if (
            testTags.some(tag =>
              ['searchcase', 'casesearch', 'referenceNumber', 'casesearchtests'].includes(tag.toLowerCase())
            )
          ) {
            caseSearchData.push(testData);
          } else {
            // Default to case submission if no specific tag found
            caseSubmissionData.push(testData);
          }
        });
      });
    });
  });

  // Remove duplicates
  const uniqueCaseSubmission = removeDuplicates(caseSubmissionData);
  const uniqueCaseSearch = removeDuplicates(caseSearchData);

  return {
    caseSubmission: uniqueCaseSubmission,
    caseSearch: uniqueCaseSearch
  };
}

// ✅ NEW: Extract tags from test annotations or title
function extractTagsFromTest(test, spec) {
  const tags = [];
  
  console.log("Debug: Extracting tags for test", spec.tags, "in spec", spec.title);
  
  // Method 2: Check spec-level tags
    if (spec && spec.tags) {
      const specTags = Array.isArray(spec.tags) ? spec.tags : [spec.tags];
      specTags.forEach(tag => {
        const cleanTag = String(tag).replace('@', '');
        if (!tags.includes(cleanTag)) {
          tags.push(cleanTag);
        }
      });
    }
  
  
  console.log("Debug: Extracted tags for test", spec.title, "=>", tags);
  return tags;
}

// ✅ NEW: Remove duplicates helper
function removeDuplicates(reportData) {
  const unique = {};
  reportData.forEach(item => {
    const key = `${item.Testname}`;
    unique[key] = item;
  });
  return Object.values(unique);
}

function pushLabeledValue(targetArray, text, label) {
  const colonIndex = text.lastIndexOf(":");
  let value = colonIndex !== -1 ? text.substring(colonIndex + 1).trim() : "";
  if (!value || value === `null` || value === `NULL`) value = "NULL";
  targetArray.push(`${label}:${value}`);
}

